{
  "name": "flyfree-glide",
  "version": "1.0.1",
  "private": true,
  "author": "girigiribauer",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox --mv3",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox --mv3",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "tsc --noEmit && eslint src tests && vitest run",
    "coverage": "vitest run --coverage",
    "test:e2e:update-fixture": "node tests/e2e/scripts/update-fixture.mjs",
    "test:e2e": "playwright test --project=chromium --project=firefox",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox"
  },
  "dependencies": {
    "@atproto/api": "^0.19.19",
    "@atproto/oauth-client-browser": "^0.3.42",
    "@emoji-mart/data": "^1.2.1",
    "emoji-mart": "^5.6.0",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.287",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^10.4.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jsdom": "^29.1.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.7",
    "wxt": "^0.20.0"
  }
}
