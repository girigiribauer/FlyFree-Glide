{
  "name": "flyfree-glide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt --browser firefox --mv3",
    "build": "wxt build",
    "build:firefox": "wxt build --browser firefox --mv3",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip --browser firefox",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "tsc --noEmit && eslint src && vitest run"
  },
  "dependencies": {
    "@atproto/api": "^0.19.19",
    "@atproto/oauth-client-browser": "^0.3.42",
    "solid-js": "^1.9.0"
  },
  "devDependencies": {
    "@solidjs/testing-library": "^0.8.10",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.0.287",
    "eslint": "^10.4.0",
    "eslint-plugin-simple-import-sort": "^13.0.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.60.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.7",
    "wxt": "^0.20.0"
  }
